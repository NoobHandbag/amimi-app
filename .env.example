# Amimi App — environment template.
# Copy to .env (gitignored) and fill. NEVER put real secrets in this example file.

# --- Public (safe to ship in the PWA bundle) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-side only (Edge Functions / ETL scripts) — never exposed to the browser ---
SUPABASE_SERVICE_ROLE_KEY=
SHOPIFY_ADMIN_TOKEN=
QROMO_WEBHOOK_SECRET=
META_ACCESS_TOKEN=

# --- App ---
APP_PIN=                 # shared PIN, hashed before storing in app_config
